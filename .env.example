# Browser-visible Clerk key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_APP_URL=http://localhost:3000

# Authentication (server only)
CLERK_SECRET_KEY=sk_test_xxx

# Anthropic Developer Platform (server only)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-your-current-supported-model-id

# Supabase (server only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo access controls
DAILY_GENERATION_LIMIT=10
ENABLE_BILLING_ENFORCEMENT=false

# Stripe test mode (optional until billing testing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx

# Deploy generated static sites to Vercel (optional)
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_GENERATED_PROJECT_PREFIX=builderkit
VERCEL_GENERATED_TARGET=preview

# Demo GitHub export (optional; server-owned repo destination)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_OWNER_TYPE=user
GITHUB_API_VERSION=2022-11-28
